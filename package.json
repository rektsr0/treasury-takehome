{
  "name": "tres",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare:tesseract": "node ./scripts/copy-tesseract-assets.mjs",
    "postinstall": "npm run prepare:tesseract",
    "build": "npm run prepare:tesseract && tsc -b && vite build",
    "build:docker": "npm run prepare:tesseract && tsc -b && vite build --base=/ --outDir dist",
    "lint": "oxlint src scripts vite.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
